---
import { siteConfig } from '../config';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  messages: Record<string, any>;
}
const { lang, messages } = Astro.props;
const hero = messages.hero;

const main = hero.titleMain as string;
const accent = hero.titleAccent as string;
const parts = main.split(accent);
const heroImg = 'https://www.rajabhakti.com/gallery/rajabhakti-park-2.jpg';
const mapsUrl = siteConfig.mapsUrl;
const coordsLabel = siteConfig.coords.label[lang];
---

<section id="home" class="relative min-h-screen flex items-end overflow-hidden">
  <img src={heroImg} alt={main} class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 bg-gradient-to-t from-teakDeep via-teakDeep/70 to-teak/40"></div>
  <div class="hero-glow absolute inset-0"></div>

  <div class="relative z-10 max-w-7xl mx-auto w-full px-5 pb-16 pt-28 grid lg:grid-cols-12 gap-10 items-end">
    <div class="lg:col-span-7 text-ivory">
      <p class="font-hand text-gold text-xl md:text-2xl mb-3">{hero.eyebrow}</p>
      <h1 class="font-display font-semibold leading-[1.05] text-5xl md:text-7xl lg:text-8xl text-ivory">
        {parts[0]}<span class="gold-text-bright">{accent}</span>{parts[1] ?? ''}
      </h1>
      <p class="mt-6 max-w-xl text-ivory/85 text-lg md:text-xl">{hero.subtitle}</p>

      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a href="#guide" class="inline-flex items-center gap-2 bg-gold text-teak font-semibold px-6 py-3 rounded-full hover:bg-goldBright transition-colors">
          {hero.cta1}
        </a>
        <a href="#food" class="inline-flex items-center gap-2 border border-gold/50 text-ivory px-6 py-3 rounded-full hover:border-goldBright hover:text-goldBright transition-colors">
          {hero.cta2}
        </a>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-5 text-sm text-ivory/80">
        <span class="stars text-lg">★ {hero.rating}</span>
        <span>{hero.reviewCount} Google</span>
        <span class="hidden sm:inline text-ivory/40">·</span>
        <span>{coordsLabel}</span>
      </div>

      <a href={mapsUrl} target="_blank" rel="noopener" class="mt-5 inline-flex items-center gap-2 text-goldBright hover:text-gold underline-offset-4 hover:underline text-sm">
        {hero.viewLocation}
      </a>
    </div>

    <!-- live weather + sunset planner -->
    <div class="lg:col-span-5">
      <div class="rounded-2xl bg-teak/55 backdrop-blur-md border border-gold/25 p-5 text-ivory shadow-2xl">
        <p id="weather-status" class="text-ivory/80 text-sm">{hero.loading}</p>
        <div id="weather-body" class="hidden">
          <div class="flex items-center justify-between">
            <span class="text-ivory/70 text-sm">{hero.liveWeather}</span>
            <span id="cur-icon" class="text-2xl">☀️</span>
          </div>
          <div class="mt-1 flex items-end gap-3">
            <span id="cur-temp" class="font-display text-5xl font-semibold text-goldBright">--°</span>
            <div class="pb-1">
              <div id="cur-cond" class="text-sm">--</div>
              <div class="text-xs text-ivory/60">💨 <span id="cur-wind">--</span></div>
            </div>
          </div>

          <div class="mt-4 pt-4 border-t border-gold/20">
            <p class="font-hand text-gold text-lg">{hero.plannerTitle}</p>
            <p class="text-xs text-ivory/60 mt-0.5">{hero.plannerNote}</p>
            <div class="mt-3 space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-ivory/70">{hero.goldenHourLabel}</span><span class="font-semibold text-goldBright">07:00 – 08:30</span></div>
              <div class="flex justify-between"><span class="text-ivory/70">{hero.crowdWarningLabel}</span><span class="font-semibold text-ivory">{hero.crowdAfter}</span></div>
            </div>
            <p class="text-[11px] text-ivory/50 mt-2">{hero.lightCaption}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ lang, weatherError: hero.weatherError }}>
  (function () {
    // Rajabhakti Park — real coordinates
    const LAT = 12.5016, LON = 99.9652;
    const LANG = lang;

    function weatherText(code, mode) {
      const map = {
        0: { th: { t: 'ท้องฟ้าโปร่งใส', s: 'แดดจัด' }, en: { t: 'Clear sky', s: 'Sunny' }, zh: { t: '晴空', s: '晴' } },
        1: { th: { t: 'โปร่งโล่ง', s: 'ส่วนใหญ่โปร่ง' }, en: { t: 'Mainly clear', s: 'Mostly clear' }, zh: { t: '少云', s: '少云' } },
        2: { th: { t: 'มีเมฆบางส่วน', s: 'มีเมฆบางส่วน' }, en: { t: 'Partly cloudy', s: 'Partly cloudy' }, zh: { t: '局部多云', s: '局部多云' } },
        3: { th: { t: 'เมฆมาก', s: 'เมฆมาก' }, en: { t: 'Overcast', s: 'Overcast' }, zh: { t: '阴', s: '阴' } },
        45: { th: { t: 'หมอก', s: 'หมอก' }, en: { t: 'Fog', s: 'Fog' }, zh: { t: '雾', s: '雾' } },
        48: { th: { t: 'หมอกแข็ง', s: 'หมอก' }, en: { t: 'Rime fog', s: 'Fog' }, zh: { t: '雾凇', s: '雾' } },
        51: { th: { t: 'ฝนปรอยเล็กน้อย', s: 'ฝนปรอย' }, en: { t: 'Light drizzle', s: 'Drizzle' }, zh: { t: '小毛毛雨', s: '毛毛雨' } },
        53: { th: { t: 'ฝนปรอยปานกลาง', s: 'ฝนปรอย' }, en: { t: 'Drizzle', s: 'Drizzle' }, zh: { t: '毛毛雨', s: '毛毛雨' } },
        55: { th: { t: 'ฝนปรอยหนัก', s: 'ฝนปรอย' }, en: { t: 'Dense drizzle', s: 'Drizzle' }, zh: { t: '浓毛毛雨', s: '毛毛雨' } },
        61: { th: { t: 'ฝนตกเล็กน้อย', s: 'ฝนตก' }, en: { t: 'Light rain', s: 'Rain' }, zh: { t: '小雨', s: '雨' } },
        63: { th: { t: 'ฝนตกปานกลาง', s: 'ฝนตก' }, en: { t: 'Rain', s: 'Rain' }, zh: { t: '中雨', s: '雨' } },
        65: { th: { t: 'ฝนตกหนัก', s: 'ฝนตก' }, en: { t: 'Heavy rain', s: 'Rain' }, zh: { t: '大雨', s: '雨' } },
        71: { th: { t: 'หิมะตกเล็กน้อย', s: 'หิมะ' }, en: { t: 'Light snow', s: 'Snow' }, zh: { t: '小雪', s: '雪' } },
        73: { th: { t: 'หิมะตกปานกลาง', s: 'หิมะ' }, en: { t: 'Snow', s: 'Snow' }, zh: { t: '中雪', s: '雪' } },
        75: { th: { t: 'หิมะตกหนัก', s: 'หิมะ' }, en: { t: 'Heavy snow', s: 'Snow' }, zh: { t: '大雪', s: '雪' } },
        80: { th: { t: 'ฝนตกเป็นระยะ', s: 'ฝนตก' }, en: { t: 'Rain showers', s: 'Showers' }, zh: { t: '阵雨', s: '阵雨' } },
        81: { th: { t: 'ฝนตกเป็นระยะปานกลาง', s: 'ฝนตก' }, en: { t: 'Rain showers', s: 'Showers' }, zh: { t: '阵雨', s: '阵雨' } },
        82: { th: { t: 'ฝนตกเป็นระยะหนัก', s: 'ฝนตก' }, en: { t: 'Violent showers', s: 'Showers' }, zh: { t: '强阵雨', s: '阵雨' } },
        95: { th: { t: 'พายุฝนฟ้าคะนอง', s: 'ฟ้าคะนอง' }, en: { t: 'Thunderstorm', s: 'Storm' }, zh: { t: '雷阵雨', s: '雷雨' } },
        96: { th: { t: 'พายุฝนฟ้าคะนองลูกเห็บ', s: 'ฟ้าคะนอง' }, en: { t: 'Thunderstorm', s: 'Storm' }, zh: { t: '雷阵雨', s: '雷雨' } },
        99: { th: { t: 'พายุฝนฟ้าคะนองลูกเห็บหนัก', s: 'ฟ้าคะนอง' }, en: { t: 'Severe thunderstorm', s: 'Storm' }, zh: { t: '强雷阵雨', s: '雷雨' } }
      };
      const e = map[code] || map[3];
      return mode === 'short' ? e[LANG].s : e[LANG].t;
    }

    function iconFor(code) {
      if (code === 0) return '☀️';
      if (code <= 2) return '🌤️';
      if (code === 3) return '☁️';
      if (code === 45 || code === 48) return '🌫️';
      if (code >= 51 && code <= 57) return '🌦️';
      if (code >= 61 && code <= 67) return '🌧️';
      if (code >= 71 && code <= 77) return '❄️';
      if (code >= 80 && code <= 82) return '🌦️';
      if (code >= 95) return '⛈️';
      return '🌡️';
    }

    const pad = (n) => String(n).padStart(2, '0');
    const fmtDate = (d) => pad(d.getHours()) + ':' + pad(d.getMinutes());

    const statusEl = document.getElementById('weather-status');
    const bodyEl = document.getElementById('weather-body');

    fetch(`https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&current=temperature_2m,weather_code,wind_speed_10m&daily=weather_code,sunrise,sunset&timezone=Asia/Bangkok&wind_speed_unit=kmh`)
      .then((r) => r.json())
      .then((d) => {
        if (!d || !d.current || !d.daily) throw new Error('bad');
        document.getElementById('cur-temp').textContent = Math.round(d.current.temperature_2m) + '°';
        document.getElementById('cur-cond').textContent = weatherText(d.current.weather_code, 'title');
        document.getElementById('cur-wind').textContent = Math.round(d.current.wind_speed_10m) + ' km/h';
        document.getElementById('cur-icon').textContent = iconFor(d.current.weather_code);

        statusEl.classList.add('hidden');
        bodyEl.classList.remove('hidden');
      })
      .catch(() => {
        statusEl.textContent = weatherError;
      });
  })();
</script>
