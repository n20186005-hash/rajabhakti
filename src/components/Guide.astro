---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const guide = messages.guide;
const guideImgs = [
  '/gallery/rajabhakti-park-2.jpg',
  '/gallery/rajabhakti-park-3.jpg',
];
---

<section id="guide" class="py-20 bg-ivory text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <p class="font-hand text-gold text-xl md:text-2xl">{guide.label}</p>
    <h2 class="font-display font-semibold text-3xl md:text-5xl text-teak mt-2">{guide.heading}</h2>
    <p class="mt-4 max-w-2xl text-ink/80">{guide.lead}</p>

    <!-- Etiquette & Dress Code -->
    {guide.etiquette && (
      <div class="mt-8 rounded-xl bg-teak/10 border border-teak/20 p-6 max-w-4xl shadow-sm">
        <h3 class="font-display text-teak text-lg font-semibold flex items-center gap-2">
          {guide.etiquette.tag}
        </h3>
        <p class="mt-2 text-ink/80 text-sm leading-relaxed">
          {guide.etiquette.text}
        </p>
      </div>
    )}

    <!-- Audio Guide -->
    {guide.audioGuide && (
      <div class="mt-6 rounded-xl bg-gold/15 border border-gold/30 p-5 max-w-4xl flex items-start gap-4">
        <div class="text-2xl mt-1">🎧</div>
        <div>
          <h4 class="font-display text-teak text-lg font-semibold">{guide.audioGuide.label}</h4>
          <p class="text-sm text-ink/80 mt-1">{guide.audioGuide.desc}</p>
        </div>
      </div>
    )}

    <div class="grid md:grid-cols-3 gap-6 mt-10">
      <!-- hours -->
      <div class="rounded-2xl border border-gold/30 bg-white/50 p-6">
        <span class="font-display text-gold text-2xl">{guide.hours.tag}</span>
        <h3 class="font-display text-xl text-teak mt-1 mb-3">{guide.hours.title}</h3>
        <p class="font-semibold text-teak">{guide.hours.time}</p>
        <ul class="mt-3 space-y-2 text-sm text-ink/75">
          {guide.hours.items.map((it) => (
            <li class="flex justify-between gap-3 border-b border-gold/15 pb-2">
              <span>{it.label}</span><span class="text-teak font-medium whitespace-nowrap">{it.value}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- fees -->
      <div class="rounded-2xl border border-gold/30 bg-white/50 p-6">
        <span class="font-display text-gold text-2xl">{guide.fees.tag}</span>
        <h3 class="font-display text-xl text-teak mt-1 mb-3">{guide.fees.title}</h3>
        <ul class="space-y-3 text-sm">
          {guide.fees.items.map((it) => (
            <li>
              <div class="font-semibold text-teak">{it.title}</div>
              <div class="text-ink/70">{it.desc}</div>
            </li>
          ))}
        </ul>
      </div>

      <!-- transport -->
      <div class="rounded-2xl border border-gold/30 bg-white/50 p-6">
        <span class="font-display text-gold text-2xl">{guide.transport.tag}</span>
        <h3 class="font-display text-xl text-teak mt-1 mb-3">{guide.transport.title}</h3>
        <ul class="space-y-3 text-sm">
          {guide.transport.items.map((it) => (
            <li>
              <div class="font-semibold text-teak">{it.title}</div>
              <div class="text-ink/70">{it.desc}</div>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Educational Itineraries & Photo Tips -->
    <div class="grid md:grid-cols-2 gap-8 mt-14 max-w-5xl">
      {guide.itineraries && (
        <div>
          <h3 class="font-display text-2xl text-teak mb-5">{guide.itinerariesTitle}</h3>
          <div class="space-y-4">
            {guide.itineraries.map((it: any) => (
              <div class="rounded-xl border border-gold/30 bg-white/60 p-5 hover:border-gold/60 transition-colors">
                <h4 class="font-semibold text-teak mb-2">{it.title}</h4>
                <p class="text-sm text-ink/75 leading-relaxed">{it.desc}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {guide.photoTips && (
        <div>
          <h3 class="font-display text-2xl text-teak mb-5">{guide.photoTips.tag}</h3>
          <div class="space-y-4">
            {guide.photoTips.tips.map((tip: any) => (
              <div class="rounded-xl border border-teak/20 bg-teak/5 p-5">
                <h4 class="font-semibold text-teak mb-2">{tip.title}</h4>
                <p class="text-sm text-ink/75 leading-relaxed">{tip.desc}</p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- FAQ -->
    <div class="mt-14 max-w-3xl">
      <h3 class="font-display text-2xl text-teak mb-5">{guide.faqTitle}</h3>
      <div class="space-y-3">
        {guide.faqs.map((f) => (
          <details class="group rounded-xl border border-gold/25 bg-white/50 p-4 open:bg-teak/5">
            <summary class="cursor-pointer font-medium text-teak flex justify-between items-center">
              {f.q}
              <span class="text-gold transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="mt-2 text-sm text-ink/75">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
